# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend
RESEND_API_KEY=re_your_key
RESEND_FROM_EMAIL=kaelo@yourdomain.com

# App URL — used in transactional email links
# Local development:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production (set this in Vercel env vars):
# NEXT_PUBLIC_APP_URL=https://atlas-passport.vercel.app

# Cron protection — generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret-here
