{
  "name": "atlas-passport",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "email": "email dev --dir emails --port 3001",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:unit:watch": "vitest --config vitest.unit.config.ts",
    "test:rls-exploits": "vitest run --config vitest.rls.config.ts",
    "test:rls-exploits:watch": "vitest --config vitest.rls.config.ts",
    "test:rls-regression": "vitest run --config vitest.regression.config.ts",
    "test:rls-regression:watch": "vitest --config vitest.regression.config.ts",
    "test:rls-all": "npm run test:rls-exploits && npm run test:rls-regression",
    "test:rls-local": "bash scripts/test-rls-local.sh",
    "test:rls-local:all": "bash scripts/test-rls-local.sh --all",
    "lint:rls-patterns": "node scripts/rls-pattern-lint.mjs",
    "lint:rls-patterns:changed": "node scripts/rls-pattern-lint.mjs --changed origin/main",
    "lint:rls-patterns:json": "node scripts/rls-pattern-lint.mjs --json",
    "prepare": "if [ -d .git ]; then cp scripts/pre-commit-rls.sh .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit; fi",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:unit:watch": "vitest --config vitest.unit.config.ts"
  },
  "dependencies": {
    "@react-email/code-block": "^0.2.1",
    "@react-email/components": "^1.0.12",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.45.0",
    "@vercel/analytics": "^2.0.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^0.400.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-email": "^6.6.5",
    "resend": "^3.5.0",
    "tailwind-merge": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.2",
    "eslint": "~9.39.4",
    "eslint-config-next": "^16.2.9",
    "eslint-plugin-react": "~7.37.5",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "//eslint-pin": "Pin eslint <10 until eslint-config-next ships stable ESLint 10 support. eslint-plugin-react@7.37.x calls the removed context.getFilename() under ESLint 10. Re-evaluate once eslint-config-next >=16.3.0 (stable) is released.",
  "overrides": {
    "prismjs": "^1.30.0",
    "cookie": "^1.1.1",
    "eslint": "~9.39.4"
  }
}
